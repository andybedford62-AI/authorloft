# ─── ENVIRONMENT VARIABLE TEMPLATE ───────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER put real credentials in this file — it is checked into git.
#
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32

# ─── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STANDARD_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."

# ─── Supabase Storage ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# ─── AWS S3 (optional — if using S3 instead of Supabase for storage) ─────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="authorloft-uploads"

# ─── Platform ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PLATFORM_DOMAIN="yourdomain.com"
