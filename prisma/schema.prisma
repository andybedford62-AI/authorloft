// AuthorLoft - Multi-tenant SaaS Author Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── System Config (singleton) ────────────────────────────────────────────────

model SystemConfig {
  id                 String   @id @default("main")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String   @default("")
  updatedAt          DateTime @updatedAt
}

// ─── Plans & Billing ─────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  STANDARD
  PREMIUM
}

model Plan {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  tier                 PlanTier  @unique
  description          String?
  monthlyPriceCents    Int       @default(0)
  annualPriceCents     Int       @default(0)
  stripePriceId        String?
  stripePriceIdMonthly String?
  stripePriceIdAnnual  String?
  maxBooks             Int?
  maxPosts             Int?
  maxStorageMb         Int?
  customDomain         Boolean   @default(false)
  salesEnabled         Boolean   @default(false)
  flipBooksLimit       Int       @default(0)    // 0 = none, -1 = unlimited, n = max count
  audioEnabled         Boolean   @default(false)
  analyticsEnabled     Boolean   @default(false)
  newsletter           Boolean   @default(false)
  featuresJson         String?
  badgeColor           String    @default("gray")
  featuredLabel        String?
  sortOrder            Int       @default(0)
  isActive             Boolean   @default(true)
  isDefault            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  authors              Author[]
  subscriptions        AuthorSubscription[]
}

// ─── Authors (Tenants) ────────────────────────────────────────────────────────

model Author {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String?
  name                 String
  displayName          String?
  slug                 String         @unique
  customDomain         String?        @unique
  bio                  String?        @db.Text
  shortBio             String?
  profileImageUrl      String?
  logoUrl              String?
  heroImageUrl         String?
  heroLayout           String         @default("author-right")
  heroTitle            String?
  heroSubtitle         String?
  accentColor          String         @default("#7B2D2D")  // legacy — no longer drives UI; kept for data safety
  baseTheme            String         @default("classic-literary") // last base theme before a genre palette was applied; used on plan downgrade
  tagline              String?
  linkedinUrl          String?
  youtubeUrl           String?
  facebookUrl          String?
  twitterUrl           String?
  instagramUrl         String?
  contactEmail         String?
  contactResponseTime  String?
  contactOpenTo        String?
  adminTheme           String         @default("light")  // admin UI preference: "light" | "dark"
  aiApiKey             String?
  aiUsageCount         Int       @default(0)
  aiUsageCap           Int       @default(20)
  aiUsageResetAt       DateTime?
  aboutStats           Json?
  credentials          Json?
  legalNotice          String?        @db.Text  // author's own legal/disclaimer notice
  legalNoticeUpdatedAt DateTime?               // stamped when author saves a new version
  showHeroBanner       Boolean        @default(true)
  heroFeaturedBookId   String?
  heroFeaturedBook     Book?          @relation("HeroFeaturedBook", fields: [heroFeaturedBookId], references: [id])
  homeTemplate         String         @default("classic")
  booksLayout          String         @default("list")
  siteTheme            String         @default("classic-literary")
  navShowAbout         Boolean        @default(true)
  navShowBooks         Boolean        @default(true)
  navShowSpecials      Boolean        @default(true)
  navShowFlipBooks     Boolean        @default(true)
  navShowBlog          Boolean        @default(false)
  navShowContact       Boolean        @default(true)
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  stripeConnectAccountId    String?   // Stripe Express connected account ID (acct_xxx)
  stripeConnectOnboarded    Boolean   @default(false) // true once onboarding is complete
  planId               String?
  plan                 Plan?          @relation(fields: [planId], references: [id])
  isActive             Boolean        @default(true)
  isSuperAdmin         Boolean        @default(false)
  emailVerified        DateTime?
  emailVerifyToken     String?        @unique
  emailVerifyExpiry    DateTime?
  passwordResetToken   String?        @unique
  passwordResetExpiry  DateTime?
  termsAcceptedAt      DateTime?      // null = never accepted; non-null = timestamp of acceptance
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  books                Book[]
  flipBooks            FlipBook[]
  genres               Genre[]
  series               Series[]
  subscribers          Subscriber[]
  campaigns            Campaign[]
  orders               Order[]
  sessions             Session[]
  accounts             Account[]
  specials             Special[]
  pages                AuthorPage[]
  posts                Post[]
  contactMessages      ContactMessage[]
  subscription         AuthorSubscription?
  impersonationsAsSuperAdmin ImpersonationLog[] @relation("ImpersonationAsSuperAdmin")
  impersonationsAsTarget     ImpersonationLog[] @relation("ImpersonationAsTarget")

  @@index([slug])
  @@index([customDomain])
}

// ─── Author Subscription ──────────────────────────────────────────────────────

model AuthorSubscription {
  id                 String   @id @default(cuid())
  authorId           String   @unique
  author             Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan     @relation(fields: [planId], references: [id])
  status             String   @default("active")
  billingInterval    String   @default("monthly")
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  renewalReminderSentAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  authorId     String
  expires      DateTime
  author       Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  authorId          String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  author            Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Genre / Category ────────────────────────────────────────────────────────

model Genre {
  id          String      @id @default(cuid())
  authorId    String
  name        String
  slug        String
  description String?
  parentId    String?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  author      Author      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Genre?      @relation("GenreChildren", fields: [parentId], references: [id])
  children    Genre[]     @relation("GenreChildren")
  books       BookGenre[]

  @@unique([authorId, slug, parentId])
  @@index([authorId])
}

// ─── Series ───────────────────────────────────────────────────────────────────

model Series {
  id          String   @id @default(cuid())
  authorId    String
  name        String
  slug        String
  description String?  @db.Text
  coverUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  books       Book[]

  @@unique([authorId, slug])
  @@index([authorId])
}

// ─── Books ────────────────────────────────────────────────────────────────────

model Book {
  id                  String               @id @default(cuid())
  authorId            String
  seriesId            String?
  title               String
  slug                String
  subtitle            String?
  description         String?              @db.Text
  shortDescription    String?
  coverImageUrl       String?
  publishedAt         DateTime?
  isbn                String?
  pageCount           Int?
  language            String               @default("en")
  priceCents          Int                  @default(0)
  stripePriceId       String?
  fileUrl             String?
  flipBookUrl         String?
  externalBuyUrl      String?
  availableFormats    String[]
  caption             String?
  releaseDate         DateTime?
  isFeatured          Boolean              @default(false)
  isPublished         Boolean              @default(true)
  directSalesEnabled  Boolean              @default(false)
  sortOrder           Int                  @default(0)
  views               Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  author              Author               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  series              Series?              @relation(fields: [seriesId], references: [id])
  genres              BookGenre[]
  orderItems          OrderItem[]
  retailerLinks       BookRetailerLink[]
  directSaleItems     BookDirectSaleItem[]
  audioTracks         BookAudioTrack[]
  previewMedia        BookPreviewMedia[]
  reviews             BookReview[]
  heroFeaturedAuthors Author[]     @relation("HeroFeaturedBook")

  @@unique([authorId, slug])
  @@index([authorId])
  @@index([seriesId])
}

// ─── Direct Sale Items ────────────────────────────────────────────────────────

enum DirectSaleFormat {
  EBOOK
  FLIPBOOK
  PRINT
}

model BookDirectSaleItem {
  id          String           @id @default(cuid())
  bookId      String
  book        Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  format      DirectSaleFormat
  label       String
  description String?
  priceCents  Int              @default(0)
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)
  fileUrl     String?          // Supabase storage URL (for display / reference)
  fileKey     String?          // Supabase storage path (e.g. "authorId/book-files/...") — used for deletion & signing
  fileName    String?          // Original filename shown in admin UI
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]

  @@index([bookId])
}

// ─── Book Audio Tracks ────────────────────────────────────────────────────────

model BookAudioTrack {
  id              String   @id @default(cuid())
  bookId          String
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  title           String                        // e.g. "Chapter 1 Excerpt", "Author Narration"
  description     String?
  url             String                        // Supabase public URL or external URL
  fileKey         String?                       // Supabase storage path — for deletion
  mimeType        String?                       // e.g. "audio/mpeg"
  durationSeconds Int?                          // optional, filled manually or from metadata
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookId])
}

// ─── Book Preview Media ───────────────────────────────────────────────────────

enum PreviewMediaType {
  IMAGE
  VIDEO
  AUDIO
}

model BookPreviewMedia {
  id               String           @id @default(cuid())
  bookId           String
  book             Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  position         Int              // 1, 2, or 3
  mediaType        PreviewMediaType @default(IMAGE)
  fileUrl          String           // main media file (image/MP4/MP3)
  fileKey          String?          // Supabase storage path for deletion
  thumbnailUrl     String?          // poster image for VIDEO/AUDIO slots
  thumbnailFileKey String?          // Supabase path for poster deletion
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([bookId, position])
  @@index([bookId])
}

// ─── Book Reviews ────────────────────────────────────────────────────────────

model BookReview {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  quote        String   @db.Text
  reviewerName String
  source       String?
  rating       Int?                              // 1–5 stars, optional
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookId])
}

// ─── Flip Books ───────────────────────────────────────────────────────────────

model FlipBook {
  id              String   @id @default(cuid())
  authorId        String
  author          Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title           String
  subtitle        String?
  description     String?  @db.Text
  slug            String
  flipBookUrl     String?
  coverImageUrl   String?
  coverImageKey   String?                       // Supabase storage path — for deletion
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([authorId, slug])
  @@index([authorId])
}

// ─── Retailer Buy Links ───────────────────────────────────────────────────────

model BookRetailerLink {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  retailer  String
  label     String
  url       String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
}

model BookGenre {
  bookId  String
  genreId String
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([bookId, genreId])
}

// ─── Specials / Promotions ────────────────────────────────────────────────────

model Special {
  id          String    @id @default(cuid())
  authorId    String
  title       String
  description String?   @db.Text
  imageUrl    String?
  ctaLabel    String?
  ctaUrl      String?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

// ─── Custom Pages ─────────────────────────────────────────────────────────────

model AuthorPage {
  id        String   @id @default(cuid())
  authorId  String
  slug      String
  title     String
  navTitle  String?
  content   String?  @db.Text
  isVisible Boolean  @default(true)
  showInNav Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, slug])
}

// ─── Blog / News Posts ────────────────────────────────────────────────────────

model Post {
  id            String    @id @default(cuid())
  authorId      String
  title         String
  slug          String
  excerpt       String?   @db.Text
  content       String?   @db.Text
  coverImageUrl String?
  publishedAt   DateTime?
  isPublished   Boolean   @default(false)
  views         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        Author    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, slug])
  @@index([authorId])
}

// ─── Newsletter Subscribers ───────────────────────────────────────────────────

model Subscriber {
  id               String   @id @default(cuid())
  authorId         String
  name             String?
  email            String
  categoryPrefs    String[]
  isConfirmed      Boolean  @default(false)
  confirmToken     String?  @unique
  unsubscribeToken String   @default(cuid())
  subscribedAt     DateTime @default(now())
  author           Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, email])
  @@index([authorId])
}

// ─── Newsletter Campaigns ─────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(cuid())
  authorId     String
  subject      String
  sentAt       DateTime @default(now())
  totalSent    Int
  totalFailed  Int
  totalTargeted Int
  author       Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

// ─── Orders & Sales ───────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

model Order {
  id                    String      @id @default(cuid())
  authorId              String
  customerEmail         String
  customerName          String?
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  totalCents            Int
  status                OrderStatus @default(PENDING)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  author                Author      @relation(fields: [authorId], references: [id])
  items                 OrderItem[]

  @@index([authorId])
  @@index([customerEmail])
}

model OrderItem {
  id             String              @id @default(cuid())
  orderId        String
  bookId         String
  saleItemId     String?             // links to BookDirectSaleItem — which format was purchased
  priceCents     Int
  fileKey        String?             // Supabase storage path — copied at purchase time for secure delivery
  downloadToken  String              @unique @default(cuid())
  downloadCount  Int                 @default(0)
  maxDownloads   Int                 @default(5)
  downloadExpiry DateTime?
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book           Book                @relation(fields: [bookId], references: [id])
  saleItem       BookDirectSaleItem? @relation(fields: [saleItemId], references: [id])

  @@index([orderId])
  @@index([downloadToken])
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id          String   @id @default(cuid())
  authorId    String
  senderName  String
  senderEmail String
  website     String?
  subject     String?
  message     String   @db.Text
  isRead      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  author      Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId, createdAt])
  @@index([authorId, isRead])
}

// ─── Platform Settings (singleton) ───────────────────────────────────────────

model PlatformSettings {
  id                    String    @id @default("singleton")
  privacyContent        String?   @db.Text
  privacyUpdatedAt      DateTime?
  termsContent          String?   @db.Text
  termsUpdatedAt        DateTime?
  contactEmail          String?
  marketingHeroImageUrl String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ─── Plan Feature Gates (singleton) ──────────────────────────────────────────
// Stores which minimum plan tier is required to access each admin feature.
// Managed via Super Admin → Feature Gates UI.

model PlanFeatureConfig {
  id        String   @id @default("singleton")
  gates     Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model StripeEvent {
  id          String   @id  // Stripe event ID (evt_xxx) — unique by design
  processedAt DateTime @default(now())
}

model ImpersonationLog {
  id            String   @id @default(cuid())
  superAdminId  String
  targetAuthorId String
  action        String   // "start" | "end"
  createdAt     DateTime @default(now())

  superAdmin    Author   @relation("ImpersonationAsSuperAdmin", fields: [superAdminId],   references: [id])
  targetAuthor  Author   @relation("ImpersonationAsTarget",     fields: [targetAuthorId], references: [id])
}